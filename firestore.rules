rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function estaAutenticado() {
      return request.auth != null;
    }

    function esAdmin() {
      return estaAutenticado()
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin';
    }

    match /usuarios/{uid} {
      allow read: if estaAutenticado() && (request.auth.uid == uid || esAdmin());
      allow create: if estaAutenticado()
        && request.auth.uid == uid
        && request.resource.data.rol == 'operador';
      allow update, delete: if esAdmin();
    }

    match /clientes/{clienteId} {
      allow read, write: if estaAutenticado();
    }

    match /equipos/{equipoId} {
      allow read, write: if estaAutenticado();
    }

    match /mantenimientos/{mantenimientoId} {
      allow read, write: if estaAutenticado();
    }

    match /ventas/{ventaId} {
      allow read, write: if estaAutenticado();
    }

    match /productos/{productoId} {
      allow read, write: if estaAutenticado();
    }

    match /cotizaciones/{cotizacionId} {
      allow read, write: if estaAutenticado();
    }

    match /configuracion/{docId} {
      allow read: if estaAutenticado();
      allow write: if esAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
